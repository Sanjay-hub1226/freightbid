# ── Server ──────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────
DATABASE_URL=postgresql://freightbid:password@localhost:5432/freightbid

# ── Redis (optional) ────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────
JWT_SECRET=change-this-to-64-random-characters-in-production
JWT_EXPIRES=24h

# ── Email (choose one) ──────────────────
# Option A: SendGrid (recommended for production)
SENDGRID_API_KEY=SG.xxxxx

# Option B: SMTP (Gmail / Zoho / custom)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

EMAIL_FROM=FreightBid Platform <noreply@yourcompany.in>
APPROVAL_EMAIL=procurement@yourcompany.in

# ── SAP S/4HANA (Phase 3 — leave false until ready) ──
SAP_INTEGRATION_ENABLED=false
SAP_BASE_URL=https://your-tenant.s4hana.ondemand.com
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=
SAP_TOKEN_URL=https://your-tenant.authentication.sap.hana.ondemand.com/oauth/token
SAP_COMPANY_CODE=1000
SAP_PURCH_ORG=PO01
SAP_PURCH_GRP=P01
SAP_PLANT=PL01
